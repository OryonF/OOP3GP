<Window x:Class="Durak.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Durak"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <!-- Labels -->
        <Label x:Name="TrumpSuitLabel" Content="Trump Suit:" HorizontalAlignment="Left" Margin="29,45,0,0" VerticalAlignment="Top"/>
        <Label x:Name="CardsRemainingLabel" Content="Cards Remaining:" HorizontalAlignment="Left" Margin="29,76,0,0" VerticalAlignment="Top"/>
        <Label x:Name="TrumpSuitValueLabel" Content="text here" HorizontalAlignment="Left" Margin="104,45,0,0" VerticalAlignment="Top"/>
        <Label x:Name="CardsRemainingValueLabel" Content="number here" HorizontalAlignment="Left" Margin="136,76,0,0" VerticalAlignment="Top"/>
        <Label x:Name="PlayerHandLabel" Content="Player Hand:" HorizontalAlignment="Left" Margin="30,169,0,0" VerticalAlignment="Top"/>
        <Label x:Name="PlayerStatusLabel" Content="Player is currently:" HorizontalAlignment="Left" Margin="29,107,0,0" VerticalAlignment="Top"/>
        <Label x:Name="PlayerStatusValueLabel" Content="text here" HorizontalAlignment="Left" Margin="140,107,0,0" VerticalAlignment="Top"/>
        <Label x:Name="CpuHandLabel" Content="CPU Hand:" HorizontalAlignment="Left" Margin="30,138,0,0" VerticalAlignment="Top"/>
        <Label x:Name="CpuHandValueLabel" Content="number here" HorizontalAlignment="Left" Margin="102,138,0,0" VerticalAlignment="Top"/>
        <Label x:Name="PlayerHandValueLabel" Content="number here" HorizontalAlignment="Left" Margin="111,169,0,0" VerticalAlignment="Top"/>

        <!-- ListBox -->
        <ListBox x:Name="PlayerHandListBox" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="31,200,603,76"/>

        <!-- Buttons -->
        <Button x:Name="UseCardButton" Content="Use Selected Card" HorizontalAlignment="Left" Margin="31,363,0,0" VerticalAlignment="Top"/>
        <Button x:Name="PassButton" Content="Pass" HorizontalAlignment="Left" Margin="170,363,0,0" VerticalAlignment="Top"/>
    </Grid>
</Window>