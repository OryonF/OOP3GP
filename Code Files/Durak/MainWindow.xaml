<Window x:Class="Durak.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Durak"
        mc:Ignorable="d"
        Title="Druak"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <!--Window Background Colour-->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1E3A2F" Offset="0"/>
            <GradientStop Color="#0F241C" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <!-- Styling -->
    <Window.Resources>

        <!-- Lable Styling -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Button Styling -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="5"/>

            <Style.Triggers>

                <!-- Hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3FA37A"/>
                </Trigger>

                <!-- Disabled "Use Selected Card" when card is invalid -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555"/>
                    <Setter Property="Foreground" Value="#AAA"/>
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>

            </Style.Triggers>
        </Style>

        <!-- ListBox Styling-->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>

    </Window.Resources>

    <Viewbox Stretch="Uniform" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid Width="800" Height="470">


            <!-- Labels -->
            <Label x:Name="Main_TrumpSuitLabel" Content="Trump Suit:" HorizontalAlignment="Left" Margin="15,14,0,0" VerticalAlignment="Top"/>
            <Label x:Name="Main_CardsRemainingLabel" Content="Cards Remaining:" HorizontalAlignment="Left" Margin="15,45,0,0" VerticalAlignment="Top"/>
            <Label x:Name="Main_TrumpSuitValueLabel" Content="text here" HorizontalAlignment="Left" Margin="90,14,0,0" VerticalAlignment="Top"/>
            <Label x:Name="Main_CardsRemainingValueLabel" Content="number here" HorizontalAlignment="Left" Margin="122,45,0,0" VerticalAlignment="Top"/>
            <Label x:Name="Main_PlayerHandLabel" Content="Player Hand:" HorizontalAlignment="Left" Margin="16,138,0,0" VerticalAlignment="Top"/>
            <Label x:Name="Main_PlayerStatusLabel" Content="Player is currently:" HorizontalAlignment="Left" Margin="15,76,0,0" VerticalAlignment="Top"/>
            <Label x:Name="Main_PlayerStatusValueLabel" Content="text here" HorizontalAlignment="Left" Margin="126,76,0,0" VerticalAlignment="Top"/>
            <Label x:Name="Main_CpuHandLabel" Content="CPU Hand:" HorizontalAlignment="Left" Margin="16,107,0,0" VerticalAlignment="Top"/>
            <Label x:Name="Main_CpuHandValueLabel" Content="number here" HorizontalAlignment="Left" Margin="88,107,0,0" VerticalAlignment="Top"/>
            <Label x:Name="Main_PlayerHandValueLabel" Content="number here" HorizontalAlignment="Left" Margin="97,138,0,0" VerticalAlignment="Top"/>

            <!-- ListBox-->
            <Border Background="#2A2A2A"
                    CornerRadius="8"
                    Padding="5"
                    Margin="17,169,617,136">

                <ListBox x:Name="Main_PlayerHandListBox"
                         d:ItemsSource="{d:SampleData ItemCount=5}"
                         SelectionChanged="Main_PlayerHandListBox_SelectionChanged"/>
            </Border>

            <!-- Buttons -->
            <Button x:Name="Main_UseCardButton" Content="Use Selected Card" HorizontalAlignment="Left" Margin="17,332,0,0" VerticalAlignment="Top" Click="Main_UseCardButton_Click"/>
            <Button x:Name="Main_PassButton" Content="Pass" HorizontalAlignment="Left" Margin="156,332,0,0" VerticalAlignment="Top" Click="Main_PassButton_Click"/>
            <Button x:Name="Main_RulesButton" Content="Game Rules" HorizontalAlignment="Left" Margin="16,373,0,0" VerticalAlignment="Top" Click="Main_RulesButton_Click"/>
            <Button x:Name="Main_StatsSettingsButton" Content="Stats &amp; Settings" HorizontalAlignment="Left" Margin="101,373,0,0" VerticalAlignment="Top" Click="Main_StatsSettingsButton_Click"/>
            <Button x:Name="Main_PlayAgainButton" Content="Play Again" HorizontalAlignment="Left" Visibility="Collapsed" Margin="466,404,0,0" VerticalAlignment="Top" Click="Main_PlayAgainButton_Click"/>


            <!-- CPU Played Cards -->
            <Image x:Name="Main_CPUPlayedCard1" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="221,76,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_CPUPlayedCard2" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="315,76,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_CPUPlayedCard3" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="409,75,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_CPUPlayedCard4" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="503,76,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_CPUPlayedCard5" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="597,76,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_CPUPlayedCard6" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="691,76,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>


            <!-- Player Played Cards -->
            <Image x:Name="Main_PlayerPlayedCard1" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="221,227,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_PlayerPlayedCard2" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="315,227,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_PlayerPlayedCard3" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="409,226,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_PlayerPlayedCard4" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="503,227,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_PlayerPlayedCard5" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="597,227,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <Image x:Name="Main_PlayerPlayedCard6" HorizontalAlignment="Left" VerticalAlignment="Top" Height="125" Width="90" Margin="691,227,0,0" Source="/empty.png">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                </Image.Effect>
            </Image>
            
            <!-- Labels -->
            <Label Content="CPU" Margin="479,40,0,0"/>
            <Label x:Name="Main_PlayerNameLabel" Content="Player: " Margin="479,370,0,0"/>

        </Grid>
    </Viewbox>
</Window>