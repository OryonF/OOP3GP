<Window x:Class="Durak.StatsSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Durak"
        mc:Ignorable="d"
        Title="StatsSettings" Height="450" Width="800">
    <Grid>
        <!-- Stats Labels -->
        <Label x:Name="StatSet_GamesPlayedLabel" Content="Games Played: " HorizontalAlignment="Left" Margin="10,36,0,0" VerticalAlignment="Top"/>
        <Label x:Name="StatSet_PlayerWinsLabel" Content="Player Wins: " HorizontalAlignment="Left" Margin="10,67,0,0" VerticalAlignment="Top"/>
        <Label x:Name="StatSet_CpuWinsLabel" Content="CPU Wins: " HorizontalAlignment="Left" Margin="10,98,0,0" VerticalAlignment="Top"/>
        <Label x:Name="StatSet_GamesPlayedValueLabel" Content="read number from json" HorizontalAlignment="Left" Margin="105,36,0,0" VerticalAlignment="Top"/>
        <Label x:Name="StatSet_PlayerWinsValueLabel" Content="read number from json" HorizontalAlignment="Left" Margin="92,67,0,0" VerticalAlignment="Top"/>
        <Label x:Name="StatSet_CpuWinsValueLabel" Content="read number from json" HorizontalAlignment="Left" Margin="83,98,0,0" VerticalAlignment="Top"/>

        <!-- Card Theme Images -->
        <Image x:Name="StatSet_NormalThemeImage" HorizontalAlignment="Left" Height="125" Margin="174,185,0,0" VerticalAlignment="Top" Width="90" Source="/n_spades_A.png">
            <Image.Effect>
                <DropShadowEffect/>
            </Image.Effect>
        </Image>
        <Image x:Name="StatSet_InvertedThemeImage" HorizontalAlignment="Left" Height="125" Margin="536,185,0,0" VerticalAlignment="Top" Width="90" Source="/s_spades_A.png">
            <Image.Effect>
                <DropShadowEffect/>
            </Image.Effect>
        </Image>
        <Image x:Name="StatSet_SillyThemeImage" HorizontalAlignment="Center" Height="125" Margin="0,185,0,0" VerticalAlignment="Top" Width="90" Source="/i_spades_A.png">
            <Image.Effect>
                <DropShadowEffect/>
            </Image.Effect>
        </Image>

        <!-- Radio Buttons -->
        <RadioButton x:Name="StatSet_NormalThemeRadioButton"
                     Content="_Normal"
                     GroupName="CardThemeGroup"
                     HorizontalAlignment="Left"
                     Margin="189,327,0,0"
                     VerticalAlignment="Top"
                     TabIndex="0" Checked="StatSet_NormalThemeRadioButton_Checked"/>

        <RadioButton x:Name="StatSet_InvertedThemeRadioButton"
                     Content="_Inverted"
                     GroupName="CardThemeGroup"
                     HorizontalAlignment="Center"
                     Margin="0,327,0,0"
                     VerticalAlignment="Top"
                     TabIndex="1" Checked="StatSet_InvertedThemeRadioButton_Checked"/>

        <RadioButton x:Name="StatSet_SillyThemeRadioButton"
                     Content="_Silly"
                     GroupName="CardThemeGroup"
                     HorizontalAlignment="Left"
                     Margin="561,327,0,0"
                     VerticalAlignment="Top"
                     TabIndex="2" Checked="StatSet_SillyThemeRadioButton_Checked"/>

        <!-- Section Label -->
        <Label x:Name="StatSet_CardThemesLabel" Content="Card Themes" HorizontalAlignment="Center" Margin="0,126,0,0" VerticalAlignment="Top"/>

        <!-- Buttons -->
        <Button x:Name="StatSet_ExitWithoutSavingButton" Content="_Return to game without saving" HorizontalAlignment="Left" Margin="218,387,0,0" VerticalAlignment="Top" IsCancel="True" TabIndex="3" Click="StatSet_ExitWithoutSavingButton_Click"/>
        <Button x:Name="StatSet_SaveAndExitButton" Content="_Close and save settings" HorizontalAlignment="Left" Margin="446,387,0,0" VerticalAlignment="Top" IsDefault="True" TabIndex="4" Click="StatSet_SaveAndExitButton_Click"/>
        <Button x:Name="StatSet_ViewGameHistoryButton" Content="View Game History" HorizontalAlignment="Left" Margin="15,139,0,0" VerticalAlignment="Top" Click="StatSet_ViewGameHistoryButton_Click"/>
    </Grid>
</Window>